# Nano Banana API key — https://nanobananaapi.ai/api-key
NANO_BANANA_API_KEY=your_key_here

# Telegram Bot token — required for Telegram Stars payments
# Use the same token as the main (video) bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Public URL of THIS service (no trailing slash).
# On Railway: use this service's domain, e.g. https://fastx-image.up.railway.app
BASE_URL=https://your-image-app.up.railway.app

# Set to "true" ONLY if this is a standalone deployment (no shared video bot).
# Leave unset or "false" when sharing a bot with the video service.
REGISTER_WEBHOOK=false

# PostgreSQL connection — use Railway Reference Variable from your Postgres service
DATABASE_URL=postgresql://user:password@host:port/dbname

# Optional
PORT=3000
